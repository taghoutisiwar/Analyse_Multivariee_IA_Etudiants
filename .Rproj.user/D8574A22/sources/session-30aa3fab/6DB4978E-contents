### 2. Importation et Exploration des Données

```{r import_data}
data <- read.csv("ai_impact_student_performance_dataset.csv")

# Aperçu des données
head(data)
str(data)
summary(data)
dim(data)
```

### 3. Valeurs Manquantes

```{r missing_values}
colSums(is.na(data))
```

### 4. Sélection des Variables Numériques et Normalisation

```{r numeric_variables}
data_num <- data %>%
  select(
    ai_dependency_score,
    ai_usage_time_minutes,
    ai_ethics_score,
    last_exam_score,
    assignment_scores_avg,
    attendance_percentage,
    concept_understanding_score,
    study_consistency_index,
    improvement_rate,
    sleep_hours,
    social_media_hours,
    class_participation_score,
    final_score
  )

# Normalisation des données
data_scaled <- scale(data_num)
```

### 5. Analyse Descriptive

#### Distribution de la Dépendance à l'IA

```{r hist_dependency}
ggplot(data, aes(x = ai_dependency_score)) +
  geom_histogram(bins = 20, fill = "steelblue", color = "black") +
  labs(
    title = "Distribution du score de dépendance à l’IA",
    x = "Score dépendance IA",
    y = "Fréquence"
  ) +
  theme_minimal()
```

#### Temps d’utilisation quotidien de l’IA

```{r hist_usage}
ggplot(data, aes(x = ai_usage_time_minutes)) +
  geom_histogram(bins = 30, fill = "darkgreen", color = "black") +
  labs(
    title = "Temps d’utilisation quotidien de l’IA",
    x = "Minutes",
    y = "Nombre d’étudiants"
  ) +
  theme_minimal()
```

#### Relations avec le Score Final

```{r relations_final_score}
# IA vs Score Final
p1 <- ggplot(data, aes(x = ai_dependency_score, y = final_score)) +
  geom_point(alpha = 0.5, color = "blue") +
  geom_smooth(method = "lm", color = "red") +
  labs(title = "Dépendance IA vs Score Final", x = "Dépendance IA", y = "Score Final") +
  theme_minimal()

# Sleep vs Score Final
p2 <- ggplot(data, aes(x = sleep_hours, y = final_score)) +
  geom_point(alpha = 0.5, color = "purple") +
  geom_smooth(method = "lm", color = "red") +
  labs(title = "Sommeil vs Score Final", x = "Heures de sommeil", y = "Score Final") +
